# Git
.git/
.gitignore
.gitattributes

# Build output (rebuilt inside the image; also avoids shipping stale local jars)
target/

# IDE / editor
.idea/
*.iml
*.iws
*.ipr
.vscode/
.classpath
.factorypath
.project
.settings/
.apt_generated/
.springBeans
.sts4-cache/

# OS cruft
.DS_Store

# Local package storage (natsu.storage-root default) -- never belongs in an image
storage/

# Docker-related files themselves
Dockerfile*
.dockerignore
docker-compose.yml

# CI / misc project tooling not needed inside the build context
.github/
HELP.md
dependency-check-suppressions.xml

# This agent's scratch notes, not part of the app
.clawdea/
